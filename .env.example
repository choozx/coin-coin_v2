# .env 템플릿 — 복사해서 .env 로 만들고 값 채우기. (.env 는 gitignore, 커밋 금지)
#   cp .env.example .env && chmod 600 .env
# 로컬: engine.* 실행 시 자동 로드(engine/env.py). 배포: docker compose 가 자동 주입.

# ── 봇 설정 ──
PRESET=presets/examples/live-strategy.json
INTERVAL=60
EQUITY=10000
COLLECT_SYMBOLS=BTCUSDC
# (선택) Discord/Slack 웹훅 — 진입/청산/에러 알림
NOTIFY_WEBHOOK=
# (선택·로컬 전용) 대시보드 '배포로 보내기'가 프리셋을 밀어넣을 배포 대시보드 주소.
# 기본은 SSH 터널(localhost:8080 → EC2:8080). 터널을 다른 포트로 열었으면 여기서 바꾼다.
DEPLOY_URL=http://localhost:8080

# ── 배포(ghcr 이미지) ──
IMAGE=ghcr.io/choozx/coin-coin_v2:latest

# ── 페이퍼 / 실거래 전환 ──
# 트레이더 컨테이너에 붙일 인자. 실거래로 올릴 때만 바꾼다.
#   --paper                  가짜 체결(기본)
#   --live                   진짜 주문. BINANCE_TESTNET=1 이면 테스트넷 가짜돈
#   --live --real-money      이 프로세스에 실돈 권한을 준다. BINANCE_TESTNET=0 으로 '시작'하려면
#                            필수이고, 대시보드의 테스트넷↔실돈 스위치도 이 권한이 있어야 실돈으로 간다.
#
# 권장 흐름: 아래처럼 '실돈 권한은 주되 테스트넷으로 시작' → 대시보드에서 검증 후 버튼으로 전환.
#   TRADE_MODE=--live --real-money   +   BINANCE_TESTNET=1
TRADE_MODE=--paper

# ── 실거래 키 (실거래 전까진 비워둠 → 페이퍼로만 동작) ──
# 발급 시: Enable Reading + Futures / 출금(Withdrawals) OFF / IP 화이트리스트.
#
# ★ 테스트넷과 메인넷은 다른 계정이라 키도 다르다. 둘을 오갈 거면 네트워크별로 넣을 것 —
#   아래 전용 변수를 먼저 보고, 없으면 공용 BINANCE_API_KEY/SECRET 로 폴백한다.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_MAINNET_API_KEY=
BINANCE_MAINNET_API_SECRET=
# 공용(네트워크 하나만 쓸 때). 위 전용 키가 있으면 그쪽이 이긴다.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# 봇이 '시작할' 네트워크. 1=테스트넷(가짜돈), 0=메인넷(실돈).
# 값 뒤에 주석을 붙이지 말 것 — 주석은 이렇게 윗줄에.
BINANCE_TESTNET=1
# post-only 지정가를 기다리는 초. 넘으면 취소하고 시장가로 추격(BBO→N초→taker).
MAKER_FILL_TIMEOUT_SEC=3
