{
  "schemaVersion": "1.0",
  "name": "RSI 과매도 역추세 (평균복귀 청산)",
  "description": "RSI 30 미만 과매도에서 롱. 평균 복귀(RSI>55) 시 익절, 12봉 내 반등 없으면 시간청산, ATR 1.5배 손절. 트레일링 없음 — 역추세엔 부적합. mean reversion 청산 정석 조합.",
  "market": {
    "exchange": "binance-futures",
    "symbol": "BTCUSDT",
    "timeframe": "15m",
    "direction": "long"
  },
  "entry": {
    "left": { "indicator": "RSI", "period": 14 },
    "cmp": "<",
    "right": 30
  },
  "exit": {
    "condition": {
      "left": { "indicator": "RSI", "period": 14 },
      "cmp": ">",
      "right": 55
    },
    "stopLoss": { "type": "atrMultiple", "value": 1.5 },
    "timeStop": { "maxBars": 12 }
  },
  "sizing": {
    "leverage": 3,
    "marginMode": "isolated",
    "size": { "type": "equityPercent", "value": 20 },
    "minLiquidationBuffer": 8,
    "maxConcurrentPositions": 1
  },
  "filter": {
    "cooldownBars": 2,
    "avoidFundingWindowMinutes": 5
  }
}
